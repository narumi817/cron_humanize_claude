<% content_for :title, t("cron_builder.title") %>
<% content_for :description, t("cron_builder.subtitle") %>

<div class="container">
  <%= link_to t("cron_builder.back_link"), locale_path(:root), class: "back-link" %>
  <h1>Cron Builder</h1>
  <p class="subtitle"><%= t("cron_builder.subtitle") %></p>

  <%= form_with url: locale_path(:build), method: :get, local: true do %>
    <div class="form-group">
      <label class="builder-label"><%= t("cron_builder.frequency_label") %></label>
      <div class="frequency-options">
        <% %w[every_minute every_n_minutes every_hour every_n_hours every_day every_week every_month every_year].each do |value| %>
          <label class="frequency-option">
            <%= radio_button_tag :frequency, value, @frequency == value %>
            <%= t("cron_builder.frequency.#{value}") %>
          </label>
        <% end %>
      </div>
    </div>

    <div class="builder-detail" data-frequency="every_n_minutes">
      <div class="builder-field">
        <%= number_field_tag :interval_minutes, params[:interval_minutes] || 15,
              min: 1, max: 59, class: "form-input-inline" %>
        <span class="builder-unit"><%= t("cron_builder.unit.minute_per") %></span>
      </div>
    </div>

    <div class="builder-detail" data-frequency="every_hour">
      <div class="builder-field">
        <span class="builder-unit"><%= t("cron_builder.unit.every_hour_prefix") %></span>
        <%= number_field_tag :minute, params[:minute] || 0,
              min: 0, max: 59, class: "form-input-inline" %>
        <span class="builder-unit"><%= t("cron_builder.unit.minute") %></span>
      </div>
    </div>

    <div class="builder-detail" data-frequency="every_n_hours">
      <div class="builder-field">
        <%= number_field_tag :interval_hours, params[:interval_hours] || 6,
              min: 1, max: 23, class: "form-input-inline" %>
        <span class="builder-unit"><%= t("cron_builder.unit.hour_interval") %></span>
        <%= number_field_tag :minute, params[:minute] || 0,
              min: 0, max: 59, class: "form-input-inline" %>
        <span class="builder-unit"><%= t("cron_builder.unit.minute") %></span>
      </div>
    </div>

    <div class="builder-detail" data-frequency="every_day">
      <div class="builder-field">
        <span class="builder-unit"><%= t("cron_builder.unit.every_day_prefix") %></span>
        <%= number_field_tag :hour, params[:hour] || 9,
              min: 0, max: 23, class: "form-input-inline" %>
        <span class="builder-unit"><%= t("cron_builder.unit.hour") %></span>
        <%= number_field_tag :minute, params[:minute] || 0,
              min: 0, max: 59, class: "form-input-inline" %>
        <span class="builder-unit"><%= t("cron_builder.unit.minute") %></span>
      </div>
    </div>

    <div class="builder-detail" data-frequency="every_week">
      <div class="builder-field">
        <span class="builder-label-inline"><%= t("cron_builder.unit.weekday") %></span>
        <div class="weekday-checkboxes">
          <% [[1], [2], [3], [4], [5], [6], [0]].each do |value| %>
            <label class="weekday-option">
              <%= check_box_tag "weekdays[]", value.first,
                    Array(params[:weekdays]).map(&:to_i).include?(value.first) %>
              <%= t("date.abbr_day_names")[value.first] %>
            </label>
          <% end %>
        </div>
      </div>
      <div class="builder-field">
        <%= number_field_tag :hour, params[:hour] || 9,
              min: 0, max: 23, class: "form-input-inline" %>
        <span class="builder-unit"><%= t("cron_builder.unit.hour") %></span>
        <%= number_field_tag :minute, params[:minute] || 0,
              min: 0, max: 59, class: "form-input-inline" %>
        <span class="builder-unit"><%= t("cron_builder.unit.minute") %></span>
      </div>
    </div>

    <div class="builder-detail" data-frequency="every_month">
      <div class="builder-field">
        <span class="builder-label-inline"><%= t("cron_builder.unit.day_of_month") %></span>
        <%= text_field_tag :days, params[:days],
              class: "form-input-inline", placeholder: t("cron_builder.placeholder.days") %>
      </div>
      <div class="builder-field">
        <%= number_field_tag :hour, params[:hour] || 9,
              min: 0, max: 23, class: "form-input-inline" %>
        <span class="builder-unit"><%= t("cron_builder.unit.hour") %></span>
        <%= number_field_tag :minute, params[:minute] || 0,
              min: 0, max: 59, class: "form-input-inline" %>
        <span class="builder-unit"><%= t("cron_builder.unit.minute") %></span>
      </div>
    </div>

    <div class="builder-detail" data-frequency="every_year">
      <div class="builder-field">
        <span class="builder-label-inline"><%= t("cron_builder.unit.month") %></span>
        <%= text_field_tag :months, params[:months],
              class: "form-input-inline", placeholder: t("cron_builder.placeholder.months") %>
      </div>
      <div class="builder-field">
        <span class="builder-label-inline"><%= t("cron_builder.unit.day_of_month") %></span>
        <%= number_field_tag :day, params[:day] || 1,
              min: 1, max: 31, class: "form-input-inline" %>
      </div>
      <div class="builder-field">
        <%= number_field_tag :hour, params[:hour] || 9,
              min: 0, max: 23, class: "form-input-inline" %>
        <span class="builder-unit"><%= t("cron_builder.unit.hour") %></span>
        <%= number_field_tag :minute, params[:minute] || 0,
              min: 0, max: 59, class: "form-input-inline" %>
        <span class="builder-unit"><%= t("cron_builder.unit.minute") %></span>
      </div>
    </div>

    <div class="form-group">
      <%= submit_tag t("cron_builder.submit"), class: "btn" %>
    </div>

    <div class="builder-secondary">
      <p class="builder-secondary-label"><%= t("cron_builder.schedule_settings") %></p>
      <div class="form-group">
        <label class="builder-label"><%= t("cron_builder.timezone_label") %></label>
        <%= select_tag :timezone,
              options_for_select(CronBuilderController::MAJOR_TIMEZONES.map { |tz|
                [ActiveSupport::TimeZone[tz]&.to_s || tz, tz]
              }, params[:timezone] || "Tokyo"),
              class: "form-select" %>
      </div>
    </div>
  <% end %>

  <% if @cron_expression %>
    <div class="result">
      <div class="description">
        <p class="result-label"><%= t("cron_builder.result_label") %></p>
        <div class="cron-output">
          <h2 class="cron-expression"><%= @cron_expression %></h2>
          <button type="button" class="copy-btn"
                  data-copy="<%= @cron_expression %>"
                  data-done="<%= t("cron_builder.copy_done") %>">
            <%= t("cron_builder.copy_button") %>
          </button>
        </div>
      </div>

      <% if @next_times&.any? %>
        <div class="next-times">
          <h3><%= t("cron_builder.next_times") %></h3>
          <ul>
            <% @next_times.each do |time| %>
              <li><%= l(time, format: :long) %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<script>
  (function () {
    var radios = document.querySelectorAll('[name="frequency"]');
    var sections = document.querySelectorAll('.builder-detail');
    function update() {
      var checked = document.querySelector('[name="frequency"]:checked');
      sections.forEach(function (s) {
        var active = checked && s.dataset.frequency === checked.value;
        s.hidden = !active;
        s.querySelectorAll('input').forEach(function (i) { i.disabled = !active; });
      });
    }
    var result = document.querySelector('.result');
    radios.forEach(function (r) {
      r.addEventListener('change', function () {
        update();
        if (result) result.hidden = true;
      });
    });
    update();

    var copyBtn = document.querySelector('.copy-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', function () {
        navigator.clipboard.writeText(copyBtn.dataset.copy).then(function () {
          var original = copyBtn.textContent;
          copyBtn.textContent = copyBtn.dataset.done;
          copyBtn.disabled = true;
          setTimeout(function () {
            copyBtn.textContent = original;
            copyBtn.disabled = false;
          }, 2000);
        });
      });
    }
  }());
</script>
