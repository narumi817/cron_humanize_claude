<% content_for :title, t("cron_expressions.index.title") %>

<div class="container">
  <h1>Cron Humanize</h1>
  <p class="subtitle"><%= t("cron_expressions.index.subtitle") %></p>

  <%= form_with url: locale_path(:root), method: :get do |f| %>
    <div class="form-group">
      <%= f.label :cron_expression, t("cron_expressions.index.label") %>
      <%= f.text_field :cron_expression,
            value: @cron_expression,
            placeholder: t("cron_expressions.index.placeholder"),
            class: "form-input",
            autofocus: true,
            required: true %>
      <div class="format-hint">
        <div class="format-labels">
          <span><%= t("cron_expressions.index.format_hint.minute") %></span>
          <span><%= t("cron_expressions.index.format_hint.hour") %></span>
          <span><%= t("cron_expressions.index.format_hint.day") %></span>
          <span><%= t("cron_expressions.index.format_hint.month") %></span>
          <span><%= t("cron_expressions.index.format_hint.weekday") %></span>
        </div>
        <p class="format-note">
          • <%= t("cron_expressions.index.format_hint.note_delimiter") %><br>
          • <%= t("cron_expressions.index.format_hint.note_wildcard") %><br>
          • <%= t("cron_expressions.index.format_hint.note_weekday") %>
        </p>
      </div>
    </div>
    <%= f.submit t("cron_expressions.index.submit"), class: "btn" %>
  <% end %>

  <div class="samples">
    <p class="samples-label"><%= t("cron_expressions.index.samples.label") %></p>
    <div class="sample-links">
      <%= link_to t("cron_expressions.index.samples.daily_9am"),
            locale_path(:root, cron_expression: "0 9 * * *"), class: "sample-btn" %>
      <%= link_to t("cron_expressions.index.samples.every_5min"),
            locale_path(:root, cron_expression: "*/5 * * * *"), class: "sample-btn" %>
      <%= link_to t("cron_expressions.index.samples.every_hour"),
            locale_path(:root, cron_expression: "0 * * * *"), class: "sample-btn" %>
      <%= link_to t("cron_expressions.index.samples.weekday_9am"),
            locale_path(:root, cron_expression: "0 9 * * 1-5"), class: "sample-btn" %>
      <%= link_to t("cron_expressions.index.samples.monthly_1st"),
            locale_path(:root, cron_expression: "0 0 1 * *"), class: "sample-btn" %>
    </div>
  </div>

  <% if @result %>
    <% if @result.error %>
      <div class="result error">
        <p class="error-message"><%= t("cron_expressions.index.error.invalid") %></p>
        <p class="error-hint">
          <%= t("cron_expressions.index.error.hint_format") %><br>
          <%= t("cron_expressions.index.error.hint_example1") %>: <code>0 9 * * *</code><br>
          <%= t("cron_expressions.index.error.hint_example2") %>: <code>*/5 * * * *</code>
        </p>
      </div>
    <% else %>
      <div class="result">
        <div class="description">
          <h2><%= @cron_expression %></h2>
          <p class="human-text"><%= @result.description %></p>
        </div>

        <% if @result.next_times.any? %>
          <div class="next-times">
            <h3><%= t("cron_expressions.index.next_times") %></h3>
            <ul>
              <% @result.next_times.each do |time| %>
                <li><%= l(time, format: :long) %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
