<% content_for :title, "Cron Humanize - cron式を日本語に変換" %>

<div class="container">
  <h1>Cron Humanize</h1>
  <p class="subtitle">cron式を人間向けの言葉に変換します</p>

  <%= form_with url: root_path, method: :get do |f| %>
    <div class="form-group">
      <%= f.label :cron_expression, "cron式" %>
      <%= f.text_field :cron_expression,
            value: @cron_expression,
            placeholder: "例: 0 9 * * 1-5",
            class: "form-input",
            autofocus: true %>
      <div class="format-hint">
        <div class="format-labels">
          <span>分</span><span>時</span><span>日</span><span>月</span><span>曜日</span>
        </div>
        <p class="format-note">• 半角スペース区切り<br>• * はすべてを意味します<br>• 曜日は 0〜6（日〜土）</p>
      </div>
    </div>
    <%= f.submit "変換する", class: "btn" %>
  <% end %>

  <div class="samples">
    <p class="samples-label">よく使う例</p>
    <div class="sample-links">
      <%= link_to "毎日9時", root_path(cron_expression: "0 9 * * *"), class: "sample-btn" %>
      <%= link_to "5分ごと", root_path(cron_expression: "*/5 * * * *"), class: "sample-btn" %>
      <%= link_to "毎時0分", root_path(cron_expression: "0 * * * *"), class: "sample-btn" %>
      <%= link_to "毎週月〜金 9時", root_path(cron_expression: "0 9 * * 1-5"), class: "sample-btn" %>
      <%= link_to "毎月1日 0時", root_path(cron_expression: "0 0 1 * *"), class: "sample-btn" %>
    </div>
  </div>

  <% if @result %>
    <% if @result.error %>
      <div class="result error">
        <p class="error-message">cron式の形式が正しくありません</p>
        <p class="error-hint">書式: 分 時 日 月 曜日（半角スペース区切り）<br>例: <code>0 9 * * *</code>（毎日9時）、<code>*/5 * * * *</code>（5分ごと）</p>
      </div>
    <% else %>
      <div class="result">
        <div class="description">
          <h2><%= @cron_expression %></h2>
          <p class="human-text"><%= @result.description %></p>
        </div>

        <% if @result.next_times.any? %>
          <div class="next-times">
            <h3>今後5回のスケジュール</h3>
            <ul>
              <% @result.next_times.each do |t| %>
                <li><%= l(t, format: :long) %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
