<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "Cron Humanize" %></title>
    <meta name="description" content="<%= t("cron_expressions.index.subtitle") %>">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Cron Humanize">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <meta property="og:title" content="<%= t("cron_expressions.index.title") %>">
    <meta property="og:description" content="<%= t("cron_expressions.index.subtitle") %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.url %>">
    <meta property="og:image" content="<%= root_url.chomp('/') %>/ogp.png">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= t("cron_expressions.index.title") %>">
    <meta name="twitter:description" content="<%= t("cron_expressions.index.subtitle") %>">
    <meta name="twitter:image" content="<%= root_url.chomp('/') %>/ogp.png">
    <link rel="alternate" hreflang="ja" href="<%= root_url %>">
    <link rel="alternate" hreflang="en" href="<%= en_root_url %>">

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="canonical" href="<%= request.url %>">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app %>

    <% if ENV['GOOGLE_ANALYTICS_ID'].present? %>
      <script async src="https://www.googletagmanager.com/gtag/js?id=<%= ENV['GOOGLE_ANALYTICS_ID'] %>"></script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '<%= ENV['GOOGLE_ANALYTICS_ID'] %>');
      </script>
    <% end %>
  </head>

  <body>
    <%= yield %>
    <footer class="footer">
      <% if ENV['BMC_URL'].present? %>
        <p class="footer-bmc">
          <%= link_to t("layouts.application.bmc"), ENV['BMC_URL'], class: "footer-bmc-link", target: "_blank", rel: "noopener noreferrer" %>
        </p>
      <% end %>
      <%= link_to t("layouts.application.privacy"), locale_path(:privacy), class: "footer-link" %>
      <span class="footer-sep">|</span>
      <% if I18n.locale == :en %>
        <%= link_to "日本語", lang_switch_path, class: "footer-link lang-link" %>
      <% else %>
        <%= link_to "English", lang_switch_path, class: "footer-link lang-link" %>
      <% end %>
      <span class="footer-sep">|</span>
      <span class="footer-copy">&copy; 2026 mizk.net</span>
    </footer>
  </body>
</html>
