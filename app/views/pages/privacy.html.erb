<% content_for :title, t("pages.privacy.title") %>

<div class="container">
  <div class="page-content">
    <%= link_to t("pages.privacy.back"), locale_path(:root), class: "back-link" %>
    <h1><%= t("pages.privacy.heading") %></h1>

    <p><%= t("pages.privacy.intro") %></p>

    <h2><%= t("pages.privacy.analytics.heading") %></h2>
    <p><%= t("pages.privacy.analytics.body") %></p>
    <p>
      <%= t("pages.privacy.analytics.optout_text",
            link: link_to(t("pages.privacy.analytics.optout_link"),
                          "https://tools.google.com/dlpage/gaoptout",
                          target: "_blank", rel: "noopener noreferrer")).html_safe %>
    </p>

    <h2><%= t("pages.privacy.data.heading") %></h2>
    <p><%= t("pages.privacy.data.body") %></p>

    <h2><%= t("pages.privacy.contact.heading") %></h2>
    <p>
      <%= t("pages.privacy.contact.body",
            link: link_to("@mizk1116", "https://x.com/mizk1116",
                          target: "_blank", rel: "noopener noreferrer")).html_safe %>
    </p>

    <p class="updated-at"><%= t("pages.privacy.updated_at") %></p>
  </div>
</div>
